---
import PublicLayout from '../layouts/PublicLayout.astro';
import type { WebRoute } from '../config/routes';

const route: WebRoute = {
  path: '/404',
  canonicalPath: null,
  canonicalPolicy: 'legacy-none',
  title: 'Sidan kunde inte hittas | Min Egenkontroll',
  description: 'Sidan du söker finns inte. Gå till startsidan eller kunskapsbanken för att hitta rätt hjälp.',
  robots: 'noindex, follow',
  page: 'home',
  shell: 'modern',
  source: 'src/pages/404.astro',
  inSitemap: false,
};
---
<PublicLayout route={route}>
  <main class="home-shell home-empty" id="main-content">
    <p class="home-kicker">404</p>
    <h1>Sidan kunde inte hittas.</h1>
    <p>Kontrollera adressen eller fortsätt till startsidan eller kunskapsbanken.</p>
    <div class="home-actions"><a class="ds-button ds-button--primary" href="/">Till startsidan</a><a class="ds-button ds-button--secondary" href="/kunskapsbank">Öppna kunskapsbanken</a></div>
  </main>
</PublicLayout>
