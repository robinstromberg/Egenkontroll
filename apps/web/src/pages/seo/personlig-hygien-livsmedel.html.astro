---
import PageRenderer from '../../components/PageRenderer.astro';
import PublicLayout from '../../layouts/PublicLayout.astro';
import { webModernRoutes } from '../../config/routes';

const route = webModernRoutes.find((candidate) => candidate.path === '/seo/personlig-hygien-livsmedel.html');
if (!route) throw new Error('Den migrerade artikeln om personlig hygien saknas i Astro-registret.');
---
<PublicLayout route={route}><PageRenderer route={route} /></PublicLayout>
