# Supabase
# Copy this file to .env.local for local development.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase access for Vercel API routes.
# Do not prefix this with VITE_ and never expose it in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# App
VITE_APP_NAME=Egenkontroll
VITE_APP_URL=https://egenkontroll-robinstrombergs-projects.vercel.app
