# Supabase
# Copy this file to .env.local for local development.
# Local development must use Supabase local development or a non-production branch.
VITE_SUPABASE_URL=https://REPLACE_WITH_NON_PRODUCTION_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY

# Server-only Supabase configuration for Vercel API routes.
SUPABASE_URL=https://REPLACE_WITH_NON_PRODUCTION_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
# Never expose this value in browser code, issues, PRs or logs.
SUPABASE_SECRET_KEY=REPLACE_WITH_SUPABASE_SECRET_KEY

# App
# Vercel Preview derives its origin from VERCEL_URL.
# Production must set the canonical app origin explicitly in Vercel.
VITE_APP_NAME=Egenkontroll
VITE_APP_URL=http://localhost:5173
