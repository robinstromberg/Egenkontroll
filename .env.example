# Supabase
# Copy this file to .env.local for local development.
# Production and Preview should define the same public Supabase project unless a separate preview project is created.
VITE_SUPABASE_URL=https://eapjywbgxtudqjrlueep.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase access for Vercel API routes.
# Do not prefix this with VITE_ and never expose it in browser code.
# Required only for server/API routes that need elevated Supabase access.
SUPABASE_SERVICE_ROLE_KEY=

# App
# Production: https://minegenkontroll.se
# Preview: use the active Vercel preview URL, or leave unset to use the production fallback in code.
VITE_APP_NAME=Egenkontroll
VITE_APP_URL=https://minegenkontroll.se
